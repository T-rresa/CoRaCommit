# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=auto_gen_message

# Node service database
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me_root_password
DB_NAME=auto_gen_message

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Node API
PORT=3001
NODE_ENV=production

# Python backends
RETRIEVAL_BACKEND_URL=http://retrieval-backend:8000
EVALUATION_BACKEND_URL=http://evaluation-backend:8001

# Retrieval / Evaluation backend
RESOURCE_PATH=/app/resource
EMBEDDING_MODEL=codebert

# Worker tuning
EVAL_WORKER_CONCURRENCY=1
EVAL_JOB_DELAY_MS=300000
EVAL_BUSY_CHECK_INTERVAL_MS=15000
EVAL_CPU_THRESHOLD=0.75
ONLINE_BUSY_TTL_SECONDS=30
